// ============================================================
// PROCESS
// ============================================================
// Tableau 10 palette
const COLORS = {
    'AtHeart':'#e15759','Hearts2Hearts':'#4e79a7','KiiiKiii':'#f28e2b',
    'ILLIT':'#76b7b2','Baby DONT Cry':'#59a14f','ifeye':'#edc948',
    'RESCENE':'#b07aa1','Say My Name':'#ff9da7','UNIS':'#9c755f',
    'MEOVV':'#bab0ac','HITGS':'#a0cbe8','USPEER':'#86bcb6'
};

const DATA = RAW.map(r => ({ total:+r[0], premium:+r[1], ad:+r[2], week:r[3], location:r[4], artist:r[5] }));
const WEEKS = [...new Set(DATA.map(d=>d.week))].sort();
const ALL_ARTISTS = [...new Set(DATA.map(d=>d.artist))].sort();

// Active artist set — all on by default
let activeArtists = new Set(ALL_ARTISTS);

// ============================================================
// CHIP UI
// ============================================================
function renderChips() {
    const container = document.getElementById('artist-chips');
    let html = '<div class="chip-controls"><button onclick="toggleAll(true)">All</button><button onclick="toggleAll(false)">None</button><button onclick="toggleOnlyAtHeart()">AtHeart Only</button></div>';
    ALL_ARTISTS.forEach(a => {
        const isActive = activeArtists.has(a);
        const isAth = a === 'AtHeart';
        const cls = `artist-chip ${isActive?'active':''} ${isAth?'atheart-chip':''}`;
        html += `<span class="${cls}" data-artist="${a}" onclick="toggleArtist('${a}')"><span class="chip-dot" style="background:${COLORS[a]}"></span>${a}</span>`;
    });
    container.innerHTML = html;
}

function toggleArtist(a) {
    if (activeArtists.has(a)) activeArtists.delete(a); else activeArtists.add(a);
    renderChips();
    dashboard.applyFilters();
}
function toggleAll(on) {
    if (on) activeArtists = new Set(ALL_ARTISTS); else activeArtists.clear();
    renderChips();
    dashboard.applyFilters();
}
function toggleOnlyAtHeart() {
    activeArtists = new Set(['AtHeart']);
    renderChips();
    dashboard.applyFilters();
}

// ============================================================
// DASHBOARD
// ============================================================
class Dashboard {
    constructor() { this.charts = {}; renderChips(); this.init(); }

    mk() { return document.getElementById('filter-metric').value; } // total|premium|ad
    mf() { return document.getElementById('filter-market').value; } // all|KR|JP
    vis() { return [...activeArtists]; }

    agg(loc, metric) {
        const r = {};
        DATA.forEach(d => {
            if (loc !== 'all' && d.location !== loc) return;
            const k = d.week+'|'+d.artist;
            r[k] = (r[k]||0) + d[metric];
        });
        return r;
    }

    validWeeks() { return WEEKS.filter(w => DATA.some(d => d.week===w && d.total>0)); }

    init() { this.renderKPIs(); this.renderTrends(); this.renderCumulative(); this.renderRatio(); this.renderGrowth(); this.renderTable(); }

    applyFilters() {
        Object.values(this.charts).forEach(c=>c.destroy());
        this.charts = {};
        this.init();
    }

    renderKPIs() {
        const m = this.mk(), mkt = this.mf(), vw = this.validWeeks();
        const lastW = vw[vw.length-1], prevW = vw[vw.length-2];
        let athTot=0, athLast=0, athPrev=0, mktTot=0;
        const artTotals = {};
        DATA.forEach(d => {
            if (d.total===0) return;
            if (mkt!=='all' && d.location!==mkt) return;
            mktTot += d[m];
            artTotals[d.artist] = (artTotals[d.artist]||0)+d[m];
            if (d.artist==='AtHeart') { athTot+=d[m]; if(d.week===lastW) athLast+=d[m]; if(d.week===prevW) athPrev+=d[m]; }
        });
        const ranked = Object.entries(artTotals).sort((a,b)=>b[1]-a[1]);
        const athRank = ranked.findIndex(e=>e[0]==='AtHeart')+1;
        const athShare = mktTot>0?(athTot/mktTot*100):0;
        const wow = athPrev>0?((athLast-athPrev)/athPrev*100):0;
        document.getElementById('kpi-row').innerHTML = `
            <div class="kpi-card highlight"><div class="kpi-label">AtHeart — 2026 YTD</div><div class="kpi-value">${fmt(athTot)}</div><div class="kpi-change ${wow>=0?'positive':'negative'}">${wow>=0?'+':''}${wow.toFixed(1)}% WoW</div></div>
            <div class="kpi-card"><div class="kpi-label">Rank</div><div class="kpi-value">#${athRank} <span style="font-size:13px;color:#999">/ ${ranked.length}</span></div><div class="kpi-change" style="color:#999">${mkt==='all'?'KR + JP':mkt==='KR'?'South Korea':'Japan'}</div></div>
            <div class="kpi-card"><div class="kpi-label">Market Share</div><div class="kpi-value">${athShare.toFixed(2)}%</div><div class="kpi-change" style="color:#999">of competitive set</div></div>
            <div class="kpi-card"><div class="kpi-label">Latest Week</div><div class="kpi-value">${fmt(athLast)}</div><div class="kpi-change" style="color:#999">${lastW}</div></div>`;
    }

    lineOpts(yFmt) {
        return {
            responsive:true, maintainAspectRatio:false,
            interaction:{mode:'index',intersect:false},
            plugins:{
                legend:{position:'bottom',labels:{usePointStyle:true,padding:12,color:'#555',font:{size:11,family:"'Segoe UI',Arial,sans-serif"}}},
                tooltip:{backgroundColor:'#fff',titleColor:'#333',bodyColor:'#555',borderColor:'#d4d4d4',borderWidth:1,titleFont:{weight:'600'},bodyFont:{size:11},padding:10,cornerRadius:3,boxPadding:4,
                    callbacks:{label:ctx=>`${ctx.dataset.label}: ${yFmt?yFmt(ctx.parsed.y):fmt(ctx.parsed.y)}`}}
            },
            scales:{
                x:{grid:{color:'#ececec',drawBorder:false},ticks:{color:'#767676',font:{size:10}},border:{color:'#d4d4d4'}},
                y:{beginAtZero:true,grid:{color:'#ececec',drawBorder:false},ticks:{color:'#767676',font:{size:10},callback:v=>yFmt?yFmt(v):fmt(v)},border:{color:'#d4d4d4'}}
            }
        };
    }

    ds(artist, data) {
        const is = artist==='AtHeart';
        return {label:artist,data,borderColor:COLORS[artist],backgroundColor:COLORS[artist]+'20',borderWidth:is?3.5:1.5,pointRadius:is?5:2,pointHoverRadius:7,tension:0.3,fill:false,order:is?0:1,pointStyle:is?'rectRot':'circle'};
    }

    renderTrends() {
        const m=this.mk(), vis=this.vis(), vw=this.validWeeks();
        ['KR','JP'].forEach(loc => {
            const id='chart-'+loc.toLowerCase(), a=this.agg(loc,m);
            const datasets = vis.map(art => this.ds(art, vw.map(w=>a[w+'|'+art]||0)));
            this.charts[id] = new Chart(document.getElementById(id),{type:'line',data:{labels:vw.map(w=>w.substring(5)),datasets},options:this.lineOpts()});
        });
    }

    renderCumulative() {
        const m=this.mk(), vis=this.vis();
        const labels=[], krT=[], jpT=[];
        vis.forEach(art => {
            let kr=0,jp=0;
            DATA.forEach(d=>{if(d.artist!==art||d.total===0)return;if(d.location==='KR')kr+=d[m];if(d.location==='JP')jp+=d[m];});
            labels.push(art); krT.push(kr); jpT.push(jp);
        });
        const idx=labels.map((_,i)=>i).sort((a,b)=>(krT[b]+jpT[b])-(krT[a]+jpT[a]));
        const sL=idx.map(i=>labels[i]),sK=idx.map(i=>krT[i]),sJ=idx.map(i=>jpT[i]);
        const bgK=sL.map(l=>l==='AtHeart'?'#e15759':'#4e79a7'), bgJ=sL.map(l=>l==='AtHeart'?'rgba(225,87,89,0.5)':'rgba(78,121,167,0.5)');
        this.charts['chart-cumulative']=new Chart(document.getElementById('chart-cumulative'),{type:'bar',data:{labels:sL,datasets:[{label:'South Korea',data:sK,backgroundColor:bgK,borderRadius:3},{label:'Japan',data:sJ,backgroundColor:bgJ,borderRadius:3}]},options:{responsive:true,maintainAspectRatio:false,indexAxis:'y',plugins:{legend:{position:'bottom',labels:{color:'#555',font:{size:11}}},tooltip:{backgroundColor:'#fff',titleColor:'#333',bodyColor:'#555',borderColor:'#d4d4d4',borderWidth:1,cornerRadius:3,callbacks:{label:ctx=>`${ctx.dataset.label}: ${fmt(ctx.parsed.x)}`}}},scales:{x:{stacked:true,grid:{color:'#ececec'},ticks:{color:'#767676',font:{size:10},callback:v=>fmt(v)},border:{color:'#d4d4d4'}},y:{stacked:true,grid:{display:false},ticks:{color:'#333',font:{size:11}},border:{color:'#d4d4d4'}}}}});
    }

    renderRatio() {
        const m=this.mk(), vis=this.vis(), vw=this.validWeeks();
        const datasets=vis.map(art=>{
            const ratios=vw.map(w=>{let kr=0,jp=0;DATA.forEach(d=>{if(d.artist!==art||d.week!==w)return;if(d.location==='KR')kr+=d[m];if(d.location==='JP')jp+=d[m];});const t=kr+jp;return t>0?(jp/t*100):0;});
            return this.ds(art,ratios);
        });
        this.charts['chart-ratio']=new Chart(document.getElementById('chart-ratio'),{type:'line',data:{labels:vw.map(w=>w.substring(5)),datasets},options:{...this.lineOpts(v=>v.toFixed(1)+'%'),scales:{x:{grid:{color:'#ececec'},ticks:{color:'#767676',font:{size:10}},border:{color:'#d4d4d4'}},y:{min:0,max:100,grid:{color:'#ececec'},ticks:{color:'#767676',font:{size:10},callback:v=>v+'%'},border:{color:'#d4d4d4'}}}}});
    }

    renderGrowth() {
        const m=this.mk(), vis=this.vis(), vw=this.validWeeks(), a=this.agg('all',m), gw=vw.slice(1);
        const datasets=vis.map(art=>{
            const g=gw.map((w,i)=>{const p=a[vw[i]+'|'+art]||0,c=a[w+'|'+art]||0;return p>0?((c-p)/p*100):0;});
            return this.ds(art,g);
        });
        this.charts['chart-growth']=new Chart(document.getElementById('chart-growth'),{type:'line',data:{labels:gw.map(w=>w.substring(5)),datasets},options:{...this.lineOpts(v=>(v>=0?'+':'')+v.toFixed(1)+'%'),scales:{x:{grid:{color:'#ececec'},ticks:{color:'#767676',font:{size:10}},border:{color:'#d4d4d4'}},y:{grid:{color:'#ececec'},ticks:{color:'#767676',font:{size:10},callback:v=>v+'%'},border:{color:'#d4d4d4'}}}}});
    }

    renderTable() {
        const m=this.mk(), mkt=this.mf(), vw=this.validWeeks();
        const lastW=vw[vw.length-1], prevW=vw[vw.length-2];
        const stats={};
        ALL_ARTISTS.forEach(art=>{let t=0,kr=0,jp=0,lw=0,pw=0;DATA.forEach(d=>{if(d.artist!==art||d.total===0)return;if(mkt!=='all'&&d.location!==mkt)return;t+=d[m];if(d.location==='KR')kr+=d[m];if(d.location==='JP')jp+=d[m];if(d.week===lastW)lw+=d[m];if(d.week===prevW)pw+=d[m];});stats[art]={t,kr,jp,lw,wow:pw>0?((lw-pw)/pw*100):0,jpR:(kr+jp)>0?(jp/(kr+jp)*100):0};});
        const sorted=Object.entries(stats).sort((a,b)=>b[1].t-a[1].t);
        let h='<table class="data-table"><thead><tr><th>Rank</th><th>Artist</th><th>Total Streams</th><th>KR</th><th>JP</th><th>JP Ratio</th><th>Latest Week</th><th>WoW %</th></tr></thead><tbody>';
        sorted.forEach(([art,s],i)=>{
            const isA=art==='AtHeart';
            h+=`<tr${isA?' class="atheart-row"':''}>`;
            h+=`<td><span class="rank-badge${i<3?' top3':''}">${i+1}</span></td>`;
            h+=`<td><span class="artist-badge"><span class="artist-dot" style="background:${COLORS[art]}"></span>${isA?'<strong>'+art+'</strong>':art}</span></td>`;
            h+=`<td>${fmt(s.t)}</td><td>${fmt(s.kr)}</td><td>${fmt(s.jp)}</td><td>${s.jpR.toFixed(1)}%</td><td>${fmt(s.lw)}</td>`;
            h+=`<td style="color:${s.wow>=0?'var(--positive)':'var(--negative)'}">${s.wow>=0?'+':''}${s.wow.toFixed(1)}%</td></tr>`;
        });
        h+='</tbody></table>';
        document.getElementById('summary-table').innerHTML=h;
    }
}

function fmt(n){if(n>=1e9)return(n/1e9).toFixed(2)+'B';if(n>=1e6)return(n/1e6).toFixed(2)+'M';if(n>=1e3)return(n/1e3).toFixed(1)+'K';return n.toLocaleString();}

