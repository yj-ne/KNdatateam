        .header-top { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 12px; margin-bottom: 4px; }
        .header-top h1 { font-size: 20px; font-weight: 600; color: var(--text-primary); letter-spacing: -0.3px; }
        .header-top h1 span { color: var(--accent-atheart); font-weight: 700; }
        .header-sub { font-size: 12px; color: var(--text-secondary); margin-bottom: 14px; border-bottom: 3px solid var(--tableau-blue); padding-bottom: 10px; }

        .filters { display: flex; gap: 14px; align-items: flex-start; flex-wrap: wrap; }
        .filter-group { display: flex; flex-direction: column; gap: 3px; }
        .filter-group label { font-size: 10px; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.6px; font-weight: 600; }
        .filter-group select { padding: 6px 10px; border: 1px solid #c8c8c8; border-radius: 3px; background: #fff; color: var(--text-primary); font-size: 12px; cursor: pointer; outline: none; }
        .filter-group select:focus { border-color: var(--tableau-blue); box-shadow: 0 0 0 2px rgba(78,121,167,0.15); }
        .filter-group select option { background: #fff; color: var(--text-primary); }

        .artist-checkboxes { display: flex; flex-wrap: wrap; gap: 6px; align-items: center; }
        .artist-chip { display: inline-flex; align-items: center; gap: 4px; padding: 4px 10px; border-radius: 3px; font-size: 11px; cursor: pointer; border: 1px solid #d4d4d4; background: #fafafa; color: var(--text-secondary); transition: all 0.15s; user-select: none; font-weight: 500; }
        .artist-chip.active { background: #fff; color: var(--text-primary); border-color: #999; box-shadow: 0 1px 2px rgba(0,0,0,0.06); }
        .artist-chip .chip-dot { width: 10px; height: 10px; border-radius: 2px; }
        .artist-chip.atheart-chip.active { border-color: var(--accent-atheart); background: rgba(225,87,89,0.06); color: var(--accent-atheart); font-weight: 700; }
        .chip-controls { display: flex; gap: 4px; margin-right: 10px; }
        .chip-controls button { padding: 4px 8px; border-radius: 3px; border: 1px solid #c8c8c8; background: #fff; color: var(--text-secondary); font-size: 10px; cursor: pointer; font-weight: 600; text-transform: uppercase; letter-spacing: 0.3px; }
        .chip-controls button:hover { background: #f0f0f0; color: var(--text-primary); border-color: #999; }

        .kpi-row { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: var(--gap); margin-bottom: var(--gap); }
        .kpi-card { background: var(--bg-card); border-radius: var(--radius); padding: 18px 20px; border: var(--border); box-shadow: var(--shadow); }
        .kpi-card.highlight { border-left: 4px solid var(--accent-atheart); }
        .kpi-label { font-size: 10px; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.6px; margin-bottom: 4px; font-weight: 600; }
        .kpi-value { font-size: 26px; font-weight: 700; color: var(--text-primary); margin-bottom: 2px; letter-spacing: -0.5px; }
        .kpi-card.highlight .kpi-value { color: var(--accent-atheart); }
        .kpi-change { font-size: 11px; font-weight: 500; }
        .kpi-change.positive { color: var(--positive); }
        .kpi-change.negative { color: var(--negative); }

        .chart-row { display: grid; grid-template-columns: 1fr 1fr; gap: var(--gap); margin-bottom: var(--gap); }
        .chart-row.full { grid-template-columns: 1fr; }
        .chart-container { background: var(--bg-card); border-radius: var(--radius); padding: 18px 20px; border: var(--border); box-shadow: var(--shadow); }
        .chart-container h3 { font-size: 13px; font-weight: 600; color: var(--text-primary); margin-bottom: 2px; }
        .chart-subtitle { font-size: 10px; color: var(--text-secondary); margin-bottom: 14px; }
        .chart-container canvas { max-height: 340px; }

        .table-section { background: var(--bg-card); border-radius: var(--radius); padding: 18px 20px; border: var(--border); box-shadow: var(--shadow); overflow-x: auto; margin-bottom: var(--gap); }
        .table-section h3 { font-size: 13px; font-weight: 600; color: var(--text-primary); margin-bottom: 14px; }
        .data-table { width: 100%; border-collapse: collapse; font-size: 12px; }
        .data-table thead th { text-align: left; padding: 8px 10px; border-bottom: 2px solid #333; color: var(--text-primary); font-weight: 700; font-size: 10px; text-transform: uppercase; letter-spacing: 0.5px; white-space: nowrap; cursor: pointer; user-select: none; }
        .data-table thead th:hover { background: #f5f5f5; }
        .data-table tbody td { padding: 8px 10px; border-bottom: 1px solid #ececec; }
        .data-table tbody tr:hover { background: #f8f8f8; }
        .data-table tbody tr.atheart-row { background: rgba(225,87,89,0.05); }
        .data-table tbody tr.atheart-row:hover { background: rgba(225,87,89,0.10); }
        .artist-badge { display: inline-flex; align-items: center; gap: 6px; }
        .artist-dot { width: 10px; height: 10px; border-radius: 2px; display: inline-block; }
        .rank-badge { display: inline-flex; align-items: center; justify-content: center; width: 22px; height: 22px; border-radius: 3px; font-size: 10px; font-weight: 700; background: #f0f0f0; color: var(--text-secondary); }
        .rank-badge.top3 { background: var(--accent-atheart); color: #fff; }
        .footer { text-align: center; padding: 14px; font-size: 10px; color: var(--text-secondary); letter-spacing: 0.3px; }

        @media (max-width: 768px) {
            .chart-row { grid-template-columns: 1fr; }
            .kpi-row { grid-template-columns: repeat(2, 1fr); }
            .filters { flex-direction: column; align-items: flex-start; }
        }
        @media print {
            body { background: #fff; }
            .dashboard-container { max-width: none; }
            .filters { display: none; }
